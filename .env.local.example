# Copy to .env.local and fill in real values. Never commit .env.local.
# All of these are read server-side only (in API routes) — do NOT prefix
# any of them with NEXT_PUBLIC_, and never import them into client components.

# VocalBridge — outbound voice calling / realtime voice agent
# (also accepts VOCAL_BRIDGE_API_KEY / VOCAL_BRIDGE_AGENT_ID / VOCAL_BRIDGE_API_URL)
VOCALBRIDGE_API_KEY=
# Required if you use an account-scoped key (not an agent key)
VOCALBRIDGE_AGENT_ID=
# Optional override (default https://vocalbridgeai.com)
# VOCALBRIDGE_API_URL=https://vocalbridgeai.com
#
# Feature flag: real Vocal Bridge dials vs test mode.
# false (default) = simulate call transcripts + mock book → iterate PayPal without burning quota
# true            = place real outbound calls
VOCALBRIDGE_CALLS_ENABLED=false

# Demo employee phones (E.164). Landing AI only extracts names; these map names → dial.
# EMPLOYEE_PHONE_RAVI=+15551234001
# EMPLOYEE_PHONE_AASHNA=+15551234002
# EMPLOYEE_PHONE_NIKHIL=+15551234003
# EMPLOYEE_PHONE_EYOHA=+15551234004

# Optional per-traveler Vocal Bridge overrides — if a specific person has
# their own dedicated agent/key instead of sharing VOCALBRIDGE_API_KEY above,
# set VOCALBRIDGE_API_KEY_<ID> (uppercase traveler id). Falls back to the
# global key when not set.
# VOCALBRIDGE_API_KEY_NIKHIL=
# VOCALBRIDGE_API_KEY_EYOHA=

# Sabre — flight & hotel shop/book (see README for how to get these)
# EPR username format: "V1:<userid>:<PCC>:<domain>"
SABRE_EPR_USERNAME=
SABRE_EPR_PASSWORD=
# Only needed if SABRE_TOKEN_VERSION=v3 (client-app-scoped auth); v2 (the
# default) only needs the EPR credentials above
SABRE_CLIENT_ID=
SABRE_CLIENT_SECRET=
SABRE_TOKEN_VERSION=v2
# test env by default; point at cert/prod base URL once you have those creds
SABRE_BASE_URL=https://api.test.sabre.com

# PayPal — split payment requests (sandbox app Client ID / Secret)
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
# sandbox (default) or live
PAYPAL_MODE=sandbox
# Optional: sandbox business login email (for dashboard only)
# PAYPAL_MERCHANT_EMAIL=sb-xxxx@business.example.com
# Used in PayPal order return/cancel URLs
APP_URL=http://localhost:3000

# LandingAI — document/image/text extraction (CEO email → travelers + trip fields)
LANDINGAI_API_KEY=

# Gmail — HR inbox that receives the CEO travel email (see README)
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=
# Optional: Gmail search query for finding the CEO→HR email
GMAIL_QUERY=subject:(travel OR trip) newer_than:7d
# Shared secret for Gmail add-on → POST /api/gmail/trigger (header X-Swarm-Secret)
GMAIL_TRIGGER_SECRET=
