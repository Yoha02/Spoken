# Copy to .env.local and fill in real values. Never commit .env.local.
# All of these are read server-side only (in API routes) — do NOT prefix
# any of them with NEXT_PUBLIC_, and never import them into client components.

# VocalBridge — outbound voice calling / realtime voice agent
VOCALBRIDGE_API_KEY=

# Sabre — flight & hotel shop/book (see README for how to get these)
# EPR username format: "V1:<userid>:<PCC>:<domain>"
SABRE_EPR_USERNAME=
SABRE_EPR_PASSWORD=
# Only needed if SABRE_TOKEN_VERSION=v3 (client-app-scoped auth); v2 (the
# default) only needs the EPR credentials above
SABRE_CLIENT_ID=
SABRE_CLIENT_SECRET=
SABRE_TOKEN_VERSION=v2
# test env by default; point at cert/prod base URL once you have those creds
SABRE_BASE_URL=https://api.test.sabre.com

# PayPal — split payment requests
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=

# LandingAI — document/image/text extraction
LANDINGAI_API_KEY=

# Gmail — reads the trip-planning email (see README for how to get the
# refresh token; free API, no billing required)
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=
# Optional: Gmail search query for finding the trip email (default below)
GMAIL_QUERY=subject:trip newer_than:7d
